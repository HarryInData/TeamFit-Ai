# ── Server ──
FLASK_DEBUG=false
FLASK_PORT=5001
PORT=5001

# ── Security ──
SECRET_KEY=your-secure-random-key-here

# ── Database ──
# Leave empty for SQLite (default), or set PostgreSQL URL for production
DATABASE_URL=

# ── AI ──
GROQ_API_KEY=your_groq_api_key_here

# ── Code Execution ──
JUDGE0_API_KEY=your_rapidapi_key_here
JUDGE0_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_HOST=judge0-ce.p.rapidapi.com

# ── CORS ──
# Comma-separated allowed origins (for production, add your Vercel URL)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://team-fit-ai.vercel.app
